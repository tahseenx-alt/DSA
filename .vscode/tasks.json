            "command": "g++ -std=c++17 \"${file}\" -o \"/Users/tahseenanwer/Desktop/DSA/Trash/${fileBasenameNoExtension}\" && \"/Users/tahseenanwer/Desktop/DSA/Trash/${fileBasenameNoExtension}\" < \"/Users/tahseenanwer/Desktop/DSA/input.txt\" > \"/Users/tahseenanwer/Desktop/DSA/output.txt\"",
